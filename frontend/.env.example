# Splitwise Clone - Frontend Environment Variables

# The base URL of your backend API.
# In local development, use:
# VITE_API_URL=http://localhost:5001/api

# In production (e.g. AWS EC2), if serving via Nginx reverse proxy on the same domain:
# VITE_API_URL=/api
# Or use the absolute URL:
VITE_API_URL=https://splitwise.yashkhurana.dev/api

# The URL of your Socket.io server
# In local development, use:
# VITE_SOCKET_URL=http://localhost:5001

# In production (e.g. AWS EC2):
# VITE_SOCKET_URL=https://splitwise.yashkhurana.dev
VITE_SOCKET_URL=/
